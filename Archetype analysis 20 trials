# ============================================================
# === ARCHETYPAL ANALYSIS (EXTREME WEIGHTED METHOD) =========
# ============================================================

def furthest_sum(X, k, random_seed=10):
    """Furthest sum initialization for diverse starting points"""
    rng = np.random.RandomState(random_seed)
    idx = rng.randint(0, X.shape[0])
    indices = [idx]
    dists = np.sum(np.abs(X - X[idx]), axis=1)
    for _ in range(k - 1):
        idx = np.argmax(dists)
        indices.append(idx)
        dists = np.minimum(dists, np.sum(np.abs(X - X[idx]), axis=1))
    return indices


def project_to_simplex(v):
    """Project vector to simplex (non-negative, sum to 1)"""
    v = np.maximum(v, 0)
    v_sum = np.sum(v)
    
    if v_sum < 1e-10:
        return np.ones_like(v) / len(v)
    
    result = v / v_sum
    
    if not np.isfinite(result).all():
        return np.ones_like(v) / len(v)
    
    return result


class AABernoulli_ExtremeWeighted:
    """
    Archetypal Analysis with Extreme Weighted C-update
    Optimized for binary damage scenarios
    """

    def __init__(self, n_archetypes, max_iter=100, tol=1e-4, random_state=None, 
                 lr=0.05, epsilon=1e-3, extremeness=4.0):
        self.n_archetypes = n_archetypes
        self.max_iter = max_iter
        self.tol = tol
        self.lr = lr
        self.epsilon = epsilon
        self.extremeness = extremeness  # Controls boundary-seeking behavior
        self.random_state = np.random.RandomState(random_state)

    def _initialize(self, X):
        """Initialize alpha, beta, and archetypes Z"""
        n, p = X.shape
        k = self.n_archetypes

        # Use furthest sum for diverse initialization
        indices = furthest_sum(X, k, self.random_state.randint(0, 10000))
        beta = np.zeros((k, n))
        for i, idx in enumerate(indices):
            beta[i, idx] = 1

        # Add small perturbation to avoid exact 0/1
        self.P = X + self.epsilon - 2 * X * self.epsilon
        
        Z = beta @ self.P
        alpha = np.ones((n, k)) / k
        return alpha, beta, Z

    def _bernoulli_loss(self, X, R):
        """Bernoulli loss for binary data"""
        R = np.clip(R, 1e-10, 1 - 1e-10)
        return -np.sum(X * np.log(R) + (1 - X) * np.log(1 - R))

    def _s_update_gradient(self, X, Z, alpha):
        """S-update using gradient descent"""
        R = alpha @ Z
        R = np.clip(R, 1e-10, 1 - 1e-10)
        
        grad = ((X / R) - ((1 - X) / (1 - R))) @ Z.T
        
        if np.any(~np.isfinite(grad)):
            alpha = alpha + self.random_state.randn(*alpha.shape) * 1e-6
        else:
            grad_norm = np.linalg.norm(grad)
            if grad_norm > 10:
                grad = grad * (10 / grad_norm)
            
            alpha = alpha + self.lr * grad
        
        alpha = np.array([project_to_simplex(a) for a in alpha])
        
        if np.any(~np.isfinite(alpha)):
            alpha = np.ones_like(alpha) / alpha.shape[1]
        
        return alpha

    def _c_update_extreme_weighted(self, X, alpha):
        """
        Extreme Weighted C-update (Boundary-seeking)
        Uses very high power to push toward single samples
        
        extremeness: Higher = closer to single sample (boundary)
                    3.0-5.0 typical for boundary-seeking
        """
        k = self.n_archetypes
        n = X.shape[0]
        beta = np.zeros((k, n))
        
        for j in range(k):
            weights = alpha[:, j]
            
            # Apply very high power transformation
            weights_extreme = np.power(weights + 1e-10, self.extremeness)
            
            if np.sum(weights_extreme) > 1e-10:
                beta[j] = weights_extreme / np.sum(weights_extreme)
            else:
                # Fallback to max if too extreme
                max_idx = np.argmax(weights)
                beta[j, max_idx] = 1.0
            
            beta[j] = np.clip(beta[j], 1e-10, 1.0)
            beta[j] = beta[j] / np.sum(beta[j])
        
        Z = beta @ self.P
        Z = np.clip(Z, self.epsilon, 1 - self.epsilon)
        
        return beta, Z

    def fit(self, X):
        """Fit the model to data"""
        n, p = X.shape
        alpha, beta, Z = self._initialize(X)
        
        R = alpha @ Z
        loss = self._bernoulli_loss(X, R)
        
        no_improvement_count = 0
        best_loss = loss

        for it in range(self.max_iter):
            # S-update: gradient descent
            alpha = self._s_update_gradient(X, Z, alpha)
            
            # C-update: extreme weighted (boundary-seeking)
            beta, Z = self._c_update_extreme_weighted(X, alpha)
            
            R = alpha @ Z
            new_loss = self._bernoulli_loss(X, R)
            
            if not np.isfinite(new_loss):
                print(f"⚠️  NaN/Inf loss at iteration {it}, stopping")
                break
            
            if abs(loss - new_loss) < self.tol * abs(loss):
                break
            
            if new_loss < best_loss:
                best_loss = new_loss
                no_improvement_count = 0
            else:
                no_improvement_count += 1
            
            if no_improvement_count > 20:
                break
            
            loss = new_loss

        self.alphas_ = alpha
        self.betas_ = beta
        self.archetypes_ = Z
        self.loss_ = loss
        
        return self


def get_archetype_scenario_ids(file_path, k, random_seed=52, n_init=3, extremeness=4.0):
    """
    Loads data, fits Archetypal Analysis with Extreme Weighted method,
    and returns dataframe of chosen representative scenarios.
    
    Parameters:
    -----------
    extremeness : float
        Controls boundary-seeking behavior. Higher = more boundary-like.
        Typical range: 3.0-5.0
    """
    try:
        full_df = pd.read_csv(file_path)
        data_df = full_df.drop('Scenario_ID', axis=1)
        X = data_df.values.astype(float)
    except Exception as e:
        print(f"Error loading data: {e}")
        return None

    best_model = None
    best_loss = np.inf
    
    # Run multiple initializations to avoid local optima
    for i in range(n_init):
        try:
            model = AABernoulli_ExtremeWeighted(
                n_archetypes=k, 
                random_state=random_seed + i, 
                max_iter=100,
                lr=0.005,
                extremeness=extremeness
            )
            model.fit(X)
            current_loss = model.loss_
            
            if np.isfinite(current_loss) and current_loss < best_loss:
                best_loss = current_loss
                best_model = model
        except Exception as e:
            continue

    if best_model is None:
        return None

    # Extract scenario indices from beta matrix
    betas = best_model.betas_
    chosen_indices = []
    used = set()
    
    for row in betas:
        sorted_cands = np.argsort(-row)  # Sort by weight (descending)
        for cand in sorted_cands:
            if cand not in used:
                chosen_indices.append(cand)
                used.add(cand)
                break
    
    # If we couldn't find unique scenarios for all k, fill with random unused
    if len(chosen_indices) < k:
        remaining_needed = k - len(chosen_indices)
        all_indices = list(range(X.shape[0]))
        unused = set(all_indices) - used
        if len(unused) >= remaining_needed:
            chosen_indices.extend(random.sample(list(unused), remaining_needed))
        else:
            chosen_indices.extend(list(unused))
    
    chosen_scenarios_df = full_df.iloc[chosen_indices].reset_index(drop=True)
    return chosen_scenarios_df

