# === EXPERIMENT DRIVER =====================================
# ============================================================

def run_trial(k, trial, base_seed=42, extremeness=4.0):
    """Runs a single trial: Fits AA with Extreme Weighted, gets scenarios, runs ARO model."""
    start_time = time.time()
    print(f"Starting Trial: k={k}, iter={trial}")
    
    # 1. Select Scenarios using Archetypal Analysis (Extreme Weighted)
    chosen_df = get_archetype_scenario_ids('damage_matrix.csv', k=k, 
                                          random_seed=base_seed + trial, 
                                          n_init=1, extremeness=extremeness)
    
    if chosen_df is None:
        return {
            "k": k,
            "trial": trial,
            "obj_value": np.nan,
            "repair_cost": np.nan,
            "penalty": np.nan,
            "runtime": time.time() - start_time
        }
    
    # 2. Solve Restoration Model
    obj, rest_cost, penalty = solve_restoration_model(chosen_df, k)
    elapsed = time.time() - start_time
    
    print(f"Finished Trial: k={k}, iter={trial} | Obj: {obj}")
    
    return {
        "k": k,
        "trial": trial,
        "obj_value": obj,
        "repair_cost": rest_cost,
        "penalty": penalty,
        "runtime": elapsed
    }

if __name__ == "__main__":
    k_values = [5, 10, 15, 20, 25, 30, 35, 40, 45, 50]
    n_trials = 20
    extremeness = 4.0  # Boundary-seeking parameter (3.0-5.0 recommended)
    results = []

    # ProcessPoolExecutor for parallel execution
    # Note: Gurobi limits parallel processes based on license type.
    # If using a single-use license, reduce max_workers to 1.
    with ProcessPoolExecutor() as executor:
        futures = []
        for k in k_values:
            for trial in range(n_trials):
                futures.append(executor.submit(run_trial, k, trial, extremeness=extremeness))
        
        for f in as_completed(futures):
            results.append(f.result())

    # Save detailed results
    df_results = pd.DataFrame(results)
    df_results.to_csv("aa_aro_results.csv", index=False)

    # Compute and print summary
    def count_valid(group):
        return group['obj_value'].notna().sum()

    summary = df_results.groupby("k").agg({
        "obj_value": ["mean", "std", "min", "max"],
        "repair_cost": ["mean", "std"],
        "penalty": ["mean", "std"],
        "runtime": "mean"
    })
    summary[('obj_value', 'num_valid')] = df_results.groupby("k").apply(lambda g: count_valid(g))
    
    print("\n=== Experiment Summary ===")
    print(summary)
    summary.to_csv("aa_aro_summary.csv")
